# Database
# Use MySQL if you configure DB_ENGINE=mysql, otherwise SQLite is used.
DB_ENGINE=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=inventory
# Optional: override the resolved URL with a full SQLAlchemy connection string
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/inventory

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=True

# CORS
CORS_ORIGINS=["http://localhost:4200", "http://localhost:3000"]

# ML/YOLO
YOLO_MODEL_PATH=models/yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
MAX_IMAGE_SIZE=1920

# OCR
PYTESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=50000000

# AI Text Suggestion (opcional - configura una de las dos opciones)
# OpenRouter (recomendado para mejores resultados)
OPENROUTER_API_KEY=tu_clave_api_de_openrouter_aqui
OPENROUTER_MODEL=gpt-4o-mini

# Ollama (alternativa local)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama2
